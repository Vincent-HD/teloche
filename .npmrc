# React Native/Metro resolves more reliably with a flat node_modules layout than
# Nub's isolated default.
node-linker=hoisted

# Expo/React Native peer ranges can lag exact package pins. Keep install moving
# and let runtime/tests catch real incompatibilities.
strict-peer-dependencies=false

# Nub 0.4.11 rejects these Effect 4 beta packages as ERR_NUB_TRUST_DOWNGRADE:
# older releases have npm trusted-publisher metadata while these releases have
# a provenance attestation. Nub accepts comma-delimited lists here; its `[]`
# array form is not read. Keep the exception limited to the required runtime.
trustPolicyExclude=effect,@effect/platform-node,@effect/platform-node-shared,@effect/vitest

# These exact Wrangler/Workers pool releases were reviewed when added, but are
# newer than Nub's release-age window. Keep the workspace-level exception pinned.
minimumReleaseAgeExclude=@cloudflare/vitest-pool-workers@0.18.6,wrangler@4.112.0
