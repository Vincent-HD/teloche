# React Native/Metro resolves more reliably with a flat node_modules layout than
# Nub's isolated default.
node-linker=hoisted

# Expo/React Native peer ranges can lag exact package pins. Keep install moving
# and let runtime/tests catch real incompatibilities.
strict-peer-dependencies=false

# Nub 0.4.11 rejects effect@4.0.0-beta.98 as ERR_NUB_TRUST_DOWNGRADE.
# This is intentional policy behavior, but the documented array form
# `trustPolicyExclude[]=effect` did not work in a local repro; the scalar form
# does. Keep this scoped to Effect instead of disabling trustPolicy globally.
trustPolicyExclude=effect
